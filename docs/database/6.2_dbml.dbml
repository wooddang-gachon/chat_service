// -----------------------------------------------------
// 1. 회원(USERS) 영역 테이블
// -----------------------------------------------------

Table USERS {
  id bigint [primary key, increment, note: '회원 고유 ID']
  phone_number varchar(50) [unique, note: '국제 규격 전화번호']
  email varchar(100) [unique, note: '이메일 주소']
  status varchar(20) [not null, default: 'ACTIVE', note: 'ACTIVE, BLOCKED, WITHDRAWING']
  created_at timestamp [not null, default: `now()`, note: '가입 일시']
  status_updated_at timestamp [not null, default: `now()`, note: '상태 갱신 일시']
  deleted_at timestamp [note: '탈퇴 완료 일시']
}

Table USER_SESSIONS {
  id bigint [primary key, increment, note: '세션 고유 ID']
  user_id bigint [not null, note: '회원 고유 ID']
  device_uuid varchar(100) [not null, note: '기기 고유 UUID']
  session_token varchar(255) [unique, not null, note: '암호화된 세션 토큰']
  is_active boolean [not null, default: true, note: '세션 활성화 여부']
  created_at timestamp [not null, default: `now()`, note: '로그인 일시']
  expires_at timestamp [note: '만료 예정 일시']
}

Table USER_BACKUPS {
  id bigint [primary key, increment, note: '백업 고유 ID']
  user_id bigint [not null, note: '회원 고유 ID']
  backup_key_hash varchar(255) [not null, note: '비밀번호 해시 값']
  s3_file_path varchar(512) [not null, note: '백업 파일 S3 경로']
  expires_at timestamp [not null, note: '백업 만료 일시 (14일)']
  created_at timestamp [not null, default: `now()`, note: '백업 일시']
}

Table PROFILES {
  user_id bigint [primary key, note: '회원 고유 ID']
  nickname varchar(50) [not null, note: '프로필 닉네임']
  profile_image_url varchar(512) [note: '원본 프로필 이미지 S3 주소']
  thumbnail_url varchar(512) [note: '축소 프로필 이미지 S3 주소']
  background_image_url varchar(512) [note: '배경 이미지 S3 주소']
  status_message varchar(255) [note: '상태 메시지']
  gender varchar(10) [note: '성별 (MALE, FEMALE, OTHER)']
  updated_at timestamp [not null, default: `now()`, note: '수정 일시']

  indexes {
    gender [name: 'idx_profiles_gender']
  }
}

Table USER_BIRTHDAYS {
  user_id bigint [primary key, note: '회원 고유 ID']
  birth_month tinyint [not null, note: '생일 월 (1~12)']
  birth_day tinyint [not null, note: '생일 일 (1~31)']
  birth_year smallint [note: '출생 연도']
  updated_at timestamp [not null, default: `now()`, note: '수정 일시']

  indexes {
    (birth_month, birth_day) [name: 'idx_user_birthdays_month_day']
  }
}

Table MULTI_PROFILES {
  id bigint [primary key, increment, note: '멀티프로필 고유 ID']
  user_id bigint [not null, note: '회원 고유 ID']
  nickname varchar(50) [not null, note: '표시 닉네임']
  profile_image_url varchar(512) [note: '프로필 이미지 S3 주소']
  background_image_url varchar(512) [note: '배경 이미지 S3 주소']
  status_message varchar(255) [note: '상태 메시지']
  created_at timestamp [not null, default: `now()`, note: '생성 일시']
}

Table FRIENDSHIPS {
  id bigint [primary key, increment, note: '관계 식별 고유 ID']
  user_id bigint [not null, note: '기준 사용자 ID']
  friend_user_id bigint [not null, note: '친구 사용자 ID']
  relationship_type varchar(20) [not null, default: 'NORMAL', note: 'NORMAL, FAVORITE, HIDDEN, BLOCKED']
  is_favorite boolean [not null, default: false, note: '즐겨찾기 여부']
  created_at timestamp [not null, default: `now()`, note: '관계 등록 일시']
  updated_at timestamp [not null, default: `now()`, note: '상태 갱신 일시']

  indexes {
    (user_id, friend_user_id) [unique, name: 'uk_friendships_user_friend']
  }
}

Table MULTI_PROFILE_MAPPINGS {
  id bigint [primary key, increment, note: '매핑 고유 ID']
  multi_profile_id bigint [not null, note: '멀티프로필 고유 ID']
  friendship_id bigint [not null, note: '친구 관계 ID']
  created_at timestamp [not null, default: `now()`, note: '지정 일시']

  indexes {
    (friendship_id, multi_profile_id) [name: 'idx_multi_profile_mappings_friend_profile']
  }
}


// -----------------------------------------------------
// 2. 채팅방(CHAT_ROOMS) 영역 테이블
// -----------------------------------------------------

Table CHAT_ROOMS {
  id bigint [primary key, increment, note: '채팅방 고유 ID']
  type varchar(20) [not null, note: 'ME, ONE_ON_ONE, GROUP, OPEN_ONE_ON_ONE, OPEN_GROUP']
  title varchar(100) [note: '채팅방 이름 (단체방용)']
  room_profile_url varchar(512) [note: '프로필 이미지 주소']
  created_at timestamp [not null, default: `now()`, note: '개설 일시']
}

Table NORMAL_CHAT_ROOMS {
  chat_room_id bigint [primary key, note: '채팅방 고유 ID']
  expires_at timestamp [note: '채팅방 만료 예정일']
}

Table OPEN_CHAT_ROOMS {
  chat_room_id bigint [primary key, note: '채팅방 고유 ID']
  owner_user_id bigint [not null, note: '방장 회원 ID']
  passcode varchar(50) [note: '입장 비밀번호']
  max_members_count int [not null, default: 100, note: '입장 제한 정원']
}

Table CHAT_ROOM_PARTICIPANTS {
  id bigint [primary key, increment, note: '참여자 고유 식별 ID']
  chat_room_id bigint [not null, note: '채팅방 고유 ID']
  user_id bigint [not null, note: '회원 고유 ID']
  role varchar(20) [not null, default: 'MEMBER', note: 'OWNER, MANAGER, MEMBER']
  joined_at timestamp [not null, default: `now()`, note: '입장 일시']
  leaved_at timestamp [note: '퇴장 일시']
  cleared_at timestamp [note: '대화 비우기 일시']
  last_read_message_id bigint [note: '마지막으로 읽은 메시지 ID']

  indexes {
    (chat_room_id, user_id) [unique, name: 'uk_participants_room_user']
  }
}

Table CHAT_ROOM_PERSONAL_SETTINGS {
  participant_id bigint [primary key, note: '참여자 고유 식별 ID']
  is_notification_on boolean [not null, default: true, note: '알림 활성화 여부']
  is_pinned boolean [not null, default: false, note: '상단 고정 여부']
  pin_order int [not null, default: 0, note: '상단 고정 정렬 순서']
  custom_background_url varchar(512) [note: '고유 배경화면 URL']
  is_input_locked boolean [not null, default: false, note: '입력창 잠금 여부']
}

Table OPEN_CHAT_PARTICIPANT_PROFILES {
  participant_id bigint [primary key, note: '참여자 고유 식별 ID']
  open_profile_nickname varchar(50) [not null, note: '가명 프로필 닉네임']
  open_profile_image_url varchar(512) [note: '가명 프로필 이미지 주소']
}

Table OPEN_CHAT_BLACKLISTS {
  id bigint [primary key, increment, note: '차단 고유 ID']
  chat_room_id bigint [not null, note: '오픈 채팅방 ID']
  blocked_user_id bigint [not null, note: '차단된 실제 가입자 user_id']
  created_at timestamp [not null, default: `now()`, note: '차단 등록 일시']

  indexes {
    (chat_room_id, blocked_user_id) [unique, name: 'uk_blacklists_room_blocked']
  }
}


// -----------------------------------------------------
// 3. 메시지(MESSAGES) 영역 테이블
// -----------------------------------------------------

Table MESSAGES {
  id bigint [primary key, increment, note: '메시지 고유 ID']
  chat_room_id bigint [not null, note: '채팅방 고유 ID']
  sender_id bigint [not null, note: '발신 회원 고유 ID']
  type varchar(20) [not null, note: 'TEXT, EMOTICON, MINI_EMOTICON, MEDIA, MAP, CONTACT, CALENDAR, SYSTEM']
  client_message_token varchar(100) [unique, not null, note: '중복 전송(멱등성) 검증용 토큰']
  unread_count int [not null, default: 0, note: '읽지 않은 사람 수']
  is_edited boolean [not null, default: false, note: '수정 여부']
  created_at timestamp [not null, default: `now()`, note: '발송 일시']
  last_edited_at timestamp [note: '최종 수정 완료 일시']

  indexes {
    (chat_room_id, id) [name: 'idx_messages_room_id_desc']
  }
}

Table TEXT_MESSAGES {
  message_id bigint [primary key, note: '메시지 고유 ID']
  content text [not null, note: '메시지 본문 텍스트']
}

Table MEDIA_MESSAGES {
  message_id bigint [primary key, note: '메시지 고유 ID']
  file_type varchar(20) [not null, note: 'PHOTO, VIDEO, FILE']
  original_s3_path varchar(512) [not null, note: '원본 파일 S3 경로']
  thumbnail_s3_path varchar(512) [note: '경량 썸네일 S3 경로']
  original_expires_at timestamp [note: '원본 파일 만료일']
  thumbnail_expires_at timestamp [note: '썸네일 만료일']
  file_size bigint [not null, default: 0, note: '파일 바이트 용량']
  created_at timestamp [not null, default: `now()`, note: '전송 일시']

  indexes {
    original_expires_at [name: 'idx_media_original_expires']
  }
}

Table EMOTICON_PACKAGES {
  id bigint [primary key, increment, note: '패키지 고유 ID']
  name varchar(100) [not null, note: '이모티콘 세트 명칭']
  publisher varchar(100) [note: '제작/배포처']
  type varchar(20) [not null, default: 'STORE', note: 'DEFAULT, STORE, MINI']
  price int [not null, default: 0, note: '구매 단가']
  created_at timestamp [not null, default: `now()` ]
}

Table EMOTICONS {
  id bigint [primary key, increment, note: '이모티콘 고유 ID']
  package_id bigint [not null, note: '이모티콘 패키지 고유 ID']
  resource_url varchar(512) [not null, note: '이모티콘 이미지 URL']
  motion_type varchar(20) [not null, default: 'STATIC', note: 'STATIC, ANIMATED, SOUND, GIANT']
  created_at timestamp [not null, default: `now()` ]
}

Table EMOTICON_MESSAGES {
  message_id bigint [primary key, note: '메시지 고유 ID']
  emoticon_id bigint [not null, note: '이모티콘 고유 ID']
}

Table SHARE_MESSAGES {
  message_id bigint [primary key, note: '메시지 고유 ID']
  share_type varchar(20) [not null, note: 'LOCATION, CONTACT, CALENDAR']
  reference_id bigint [note: '공유 정보 식별 ID 매핑']
  description varchar(255) [note: '공유 설명 요약']
}

Table MESSAGE_EDIT_HISTORIES {
  id bigint [primary key, increment, note: '이력 식별 ID']
  message_id bigint [not null, note: '메시지 고유 ID']
  original_content text [not null, note: '수정되기 전 원본 본문']
  edited_at timestamp [not null, default: `now()`, note: '수정 일시']
}

Table MESSAGE_REPLIES {
  id bigint [primary key, increment, note: '답장 관계 ID']
  parent_message_id bigint [not null, note: '부모 메시지 ID']
  child_message_id bigint [not null, note: '자식 메시지 ID']
}

Table MESSAGE_MENTIONS {
  id bigint [primary key, increment, note: '멘션 고유 ID']
  message_id bigint [not null, note: '메시지 고유 ID']
  target_user_id bigint [not null, note: '멘션 대상 유저 ID']
}

Table CHAT_NOTICES {
  id bigint [primary key, increment, note: '공지 고유 ID']
  chat_room_id bigint [not null, note: '채팅방 고유 ID']
  message_id bigint [not null, note: '메시지 고유 ID']
  creator_id bigint [not null, note: '공지 등록 유저 ID']
  created_at timestamp [not null, default: `now()`, note: '등록 일시']
}


// -----------------------------------------------------
// 4. 구독 및 부가 정보 영역 테이블
// -----------------------------------------------------

Table DRAWER_SUBSCRIPTIONS {
  user_id bigint [primary key, note: '회원 고유 ID']
  is_active boolean [not null, default: false, note: '톡서랍 활성화 유무']
  started_at timestamp [note: '구독 시작일']
  expires_at timestamp [note: '구독 만료일']
}

Table USER_EMOTICON_LICENSES {
  id bigint [primary key, increment, note: '라이선스 고유 ID']
  user_id bigint [not null, note: '회원 고유 ID']
  package_id bigint [not null, note: '이모티콘 패키지 고유 ID']
  purchased_at timestamp [not null, default: `now()`, note: '구매 완료 일시']
  expires_at timestamp [note: '라이선스 만료일']
}

Table USER_SUBSCRIPTIONS {
  user_id bigint [primary key, note: '회원 고유 ID']
  status varchar(20) [not null, default: 'INACTIVE', note: 'ACTIVE, INACTIVE, SUSPENDED']
  started_at timestamp [note: '구독 시작일']
  next_billing_at timestamp [note: '다음 결제 예정일']
  expires_at timestamp [note: '구독 종료일']
}

Table EMOTICON_RECOMMEND_TAGS {
  id bigint [primary key, increment, note: '추천 태그 ID']
  tag_word varchar(50) [not null, note: '추천 단어 키워드']
  emoticon_id bigint [not null, note: '개별 이모티콘 ID']

  indexes {
    tag_word [name: 'idx_emoticon_recommend_tags_word']
  }
}

Table TEXT_EMOJI_MAPPINGS {
  id bigint [primary key, increment, note: '매핑 고유 ID']
  text_pattern varchar(50) [not null, note: '치환 대상 문자 기호 패턴']
  emoji_image_url varchar(512) [not null, note: '이모지 이미지 URL']
}


// -----------------------------------------------------
// 5. 일정 및 외부 정산 영역 테이블
// -----------------------------------------------------

Table CALENDAR_EVENTS {
  id bigint [primary key, increment, note: '일정 고유 ID']
  chat_room_id bigint [not null, note: '채팅방 고유 ID']
  creator_id bigint [not null, note: '등록 유저 ID']
  title varchar(100) [not null, note: '일정 제목']
  start_time timestamp [not null, note: '시작 시각']
  end_time timestamp [not null, note: '종료 시각']
  location varchar(255) [note: '일정 장소']
  description text [note: '세부 내용']
  created_at timestamp [not null, default: `now()`, note: '등록 일시']
}

Table CALENDAR_EVENT_ATTENDEES {
  id bigint [primary key, increment, note: '참석자 등록 고유 ID']
  event_id bigint [not null, note: '일정 고유 ID']
  user_id bigint [not null, note: '회원 고유 ID']
  attendance_status varchar(20) [not null, default: 'UNRESPONDED', note: 'ATTENDING, ABSENT, TENTATIVE, UNRESPONDED']
  responded_at timestamp [note: '답변 일시']

  indexes {
    (event_id, user_id) [unique, name: 'uk_calendar_event_attendees_event_user']
  }
}

Table BIZ_MESSAGES {
  id bigint [primary key, increment, note: '비즈니스 발송 데이터 고유 ID']
  partner_id bigint [not null, note: '파트너사 고유 식별 ID']
  phone_number varchar(50) [not null, note: '수신 국제 규격 폰번호']
  type varchar(20) [not null, note: 'ALIMTALK, FRIENDTALK']
  content text [not null, note: '발송 본문']
  created_at timestamp [not null, default: `now()`, note: '접수 일시']
}

Table BIZ_MESSAGE_DELIVERIES {
  biz_message_id bigint [primary key, note: '비즈니스 발송 데이터 고유 ID']
  is_delivered boolean [not null, default: false, note: '수신 도달 여부']
  failure_code varchar(50) [note: '실패 오류 코드']
  is_sms_fallback_delivered boolean [not null, default: false, note: 'SMS 우회 성공 유무']
  billing_amount decimal(10,2) [not null, default: 0.00, note: '과금 부과 단금']
  delivered_at timestamp [note: '수신 완료 시각']
}


// -----------------------------------------------------
// 6. 마케팅, 기프티콘, 리액션 영역 테이블
// -----------------------------------------------------

Table USER_ACQUISITIONS {
  user_id bigint [primary key, note: '회원 고유 ID']
  utm_source varchar(50) [note: '유입 소스 정보']
  utm_medium varchar(50) [note: '유입 매체 형태']
  utm_campaign varchar(100) [note: '유입 광고 캠페인 명']
  created_at timestamp [not null, default: `now()`, note: '수집 기록 시각']
}

Table BEHAVIOR_LOGS {
  id bigint [primary key, increment, note: '로그 식별 ID']
  user_id bigint [not null, note: '회원 고유 ID (물리 FK 없음)']
  action_type varchar(50) [not null, note: '행동 로그 형태']
  target_element varchar(100) [note: '행동 대상 컴포넌트']
  created_at timestamp [not null, default: `now()`, note: '기록 시각']

  indexes {
    user_id [name: 'idx_behavior_logs_user']
  }
}

Table CART_ITEMS {
  id bigint [primary key, increment, note: '품목 식별 ID']
  user_id bigint [not null, note: '회원 고유 ID']
  product_id bigint [not null, note: '선물 상품 ID']
  status varchar(20) [not null, default: 'ACTIVE', note: 'ACTIVE, ABANDONED, PURCHASED']
  quantity int [not null, default: 1, note: '수량']
  created_at timestamp [not null, default: `now()`, note: '담은 시각']
  updated_at timestamp [not null, default: `now()`, note: '상태 갱신 시각']

  indexes {
    (status, updated_at) [name: 'idx_cart_items_status_updated']
  }
}

Table GIFT_COUPONS {
  id bigint [primary key, increment, note: '쿠폰 고유 ID']
  coupon_code varchar(100) [unique, not null, note: '기프티콘 번호']
  sender_user_id bigint [not null, note: '송신자 ID']
  receiver_user_id bigint [not null, note: '수신자 ID']
  product_id bigint [not null, note: '상품 ID']
  status varchar(50) [not null, default: 'WAITING_RECEIVE', note: 'WAITING_RECEIVE, RECEIVED, USED, REFUNDED']
  price_amount decimal(18,2) [not null, note: '결제 금액']
  refund_recipient_role varchar(20) [not null, note: '환불 대상 구분']
  created_at timestamp [not null, default: `now()`, note: '발송 일시']
  updated_at timestamp [not null, default: `now()`, note: '상태 갱신 일시']
}

Table GIFT_COUPON_HISTORIES {
  id bigint [primary key, increment, note: '이력 고유 ID']
  gift_coupon_id bigint [not null, note: '모바일 쿠폰 ID']
  status_from varchar(50) [not null, note: '이전 상태']
  status_to varchar(50) [not null, note: '갱신 상태']
  transaction_identifier varchar(100) [note: 'PG 결제 승인 번호']
  changed_at timestamp [not null, default: `now()`, note: '변경 기록 일시']
}

Table GIFT_COUPON_ARCHIVES {
  id bigint [primary key, note: '원본 ID 보존']
  coupon_code varchar(100) [unique, not null, note: '마스킹된 기프티콘 번호']
  sender_user_id bigint [note: '탈퇴 회원 송신 ID (FK 없음)']
  receiver_user_id bigint [note: '탈퇴 회원 수신 ID (FK 없음)']
  product_id bigint [not null, note: '상품 ID']
  status varchar(50) [not null, note: '이관 시점 최종 상태']
  price_amount decimal(18,2) [not null, note: '결제 금액']
  refund_recipient_role varchar(20) [not null, note: '환불 대상 구분']
  created_at timestamp [not null, note: '원거래 최초 일시']
  updated_at timestamp [not null, note: '원거래 최종 갱신 일시']
  archived_at timestamp [not null, default: `now()`, note: '이관 처리 완료 일시']
}

Table PROFILE_ASSETS {
  id bigint [primary key, increment, note: '사진첩 에셋 ID']
  user_id bigint [not null, note: '회원 고유 ID']
  asset_type varchar(20) [not null, note: 'PROFILE_IMAGE, BACKGROUND_IMAGE']
  image_url varchar(512) [not null, note: 'S3 파일 URL']
  visibility varchar(20) [not null, default: 'PUBLIC', note: 'PUBLIC, PRIVATE']
  status varchar(20) [not null, default: 'ACTIVE', note: 'ACTIVE, DELETED']
  created_at timestamp [not null, default: `now()`, note: '업로드 일시']
}

Table MESSAGE_REACTIONS {
  id bigint [primary key, increment, note: '리액션 고유 ID']
  message_id bigint [not null, note: '공감 대상 메시지 ID']
  user_id bigint [not null, note: '리액션을 남긴 유저 ID']
  reaction_type varchar(20) [not null, note: 'LIKE, HEART, OK, HAHA, WOW, SAD']
  created_at timestamp [not null, default: `now()`, note: '등록 일시']
  updated_at timestamp [not null, default: `now()`, note: '갱신 일시']

  indexes {
  
    (message_id, user_id) [unique, name: 'uk_message_reactions_msg_user']
  }
}


// -----------------------------------------------------
// 7. 관계 정의 (References)
// -----------------------------------------------------

// 7.1 회원 연관 관계 (1:1 및 1:N)
Ref: USER_SESSIONS.user_id > USERS.id [delete: cascade]
Ref: USER_BACKUPS.user_id > USERS.id [delete: cascade]
Ref: PROFILES.user_id - USERS.id [delete: cascade]
Ref: USER_BIRTHDAYS.user_id - USERS.id [delete: cascade]
Ref: MULTI_PROFILES.user_id > USERS.id [delete: cascade]
Ref: FRIENDSHIPS.user_id > USERS.id [delete: cascade]
Ref: FRIENDSHIPS.friend_user_id > USERS.id [delete: cascade]
Ref: MULTI_PROFILE_MAPPINGS.multi_profile_id > MULTI_PROFILES.id [delete: cascade]
Ref: MULTI_PROFILE_MAPPINGS.friendship_id > FRIENDSHIPS.id [delete: cascade]

// 7.2 채팅방 및 참여자 상속 및 상세 매핑
Ref: NORMAL_CHAT_ROOMS.chat_room_id - CHAT_ROOMS.id [delete: cascade]
Ref: OPEN_CHAT_ROOMS.chat_room_id - CHAT_ROOMS.id [delete: cascade]
Ref: OPEN_CHAT_ROOMS.owner_user_id > USERS.id [delete: restrict]
Ref: CHAT_ROOM_PARTICIPANTS.chat_room_id > CHAT_ROOMS.id [delete: cascade]
Ref: CHAT_ROOM_PARTICIPANTS.user_id > USERS.id [delete: cascade]
Ref: CHAT_ROOM_PERSONAL_SETTINGS.participant_id - CHAT_ROOM_PARTICIPANTS.id [delete: cascade]
Ref: OPEN_CHAT_PARTICIPANT_PROFILES.participant_id - CHAT_ROOM_PARTICIPANTS.id [delete: cascade]
Ref: OPEN_CHAT_BLACKLISTS.chat_room_id > CHAT_ROOMS.id [delete: cascade]
Ref: OPEN_CHAT_BLACKLISTS.blocked_user_id > USERS.id [delete: cascade]

// 7.3 메시지 공통 메타 및 유형별 1:1 수직 분할
Ref: MESSAGES.chat_room_id > CHAT_ROOMS.id [delete: cascade]
Ref: MESSAGES.sender_id > USERS.id [delete: restrict]
Ref: TEXT_MESSAGES.message_id - MESSAGES.id [delete: cascade]
Ref: MEDIA_MESSAGES.message_id - MESSAGES.id [delete: cascade]
Ref: EMOTICON_MESSAGES.message_id - MESSAGES.id [delete: cascade]
Ref: EMOTICONS.package_id > EMOTICON_PACKAGES.id [delete: cascade]
Ref: EMOTICON_MESSAGES.emoticon_id > EMOTICONS.id [delete: restrict]
Ref: SHARE_MESSAGES.message_id - MESSAGES.id [delete: cascade]

// 7.4 메시지 부가 기능 관계 (답장, 멘션, 공지, 공감)
Ref: MESSAGE_EDIT_HISTORIES.message_id > MESSAGES.id [delete: cascade]
Ref: MESSAGE_REPLIES.parent_message_id > MESSAGES.id [delete: cascade]
Ref: MESSAGE_REPLIES.child_message_id > MESSAGES.id [delete: cascade]
Ref: MESSAGE_MENTIONS.message_id > MESSAGES.id [delete: cascade]
Ref: MESSAGE_MENTIONS.target_user_id > USERS.id [delete: cascade]
Ref: CHAT_NOTICES.chat_room_id > CHAT_ROOMS.id [delete: cascade]
Ref: CHAT_NOTICES.message_id > MESSAGES.id [delete: cascade]
Ref: CHAT_NOTICES.creator_id > USERS.id [delete: restrict]

// 7.5 구독 및 정산, 캘린더 부가 관계
Ref: DRAWER_SUBSCRIPTIONS.user_id - USERS.id [delete: cascade]
Ref: USER_EMOTICON_LICENSES.user_id > USERS.id [delete: cascade]
Ref: USER_EMOTICON_LICENSES.package_id > EMOTICON_PACKAGES.id [delete: restrict]
Ref: USER_SUBSCRIPTIONS.user_id - USERS.id [delete: cascade]
Ref: EMOTICON_RECOMMEND_TAGS.emoticon_id > EMOTICONS.id [delete: cascade]
Ref: CALENDAR_EVENTS.chat_room_id > CHAT_ROOMS.id [delete: cascade]
Ref: CALENDAR_EVENTS.creator_id > USERS.id [delete: restrict]
Ref: CALENDAR_EVENT_ATTENDEES.event_id > CALENDAR_EVENTS.id [delete: cascade]
Ref: CALENDAR_EVENT_ATTENDEES.user_id > USERS.id [delete: cascade]
Ref: BIZ_MESSAGE_DELIVERIES.biz_message_id - BIZ_MESSAGES.id [delete: cascade]

// 7.6 마케팅 및 커머스, 리액션 관계 (BEHAVIOR_LOGS 및 ARCHIVES는 물리 FK가 없음)
Ref: USER_ACQUISITIONS.user_id - USERS.id [delete: cascade]
Ref: CART_ITEMS.user_id > USERS.id [delete: cascade]
Ref: GIFT_COUPONS.sender_user_id > USERS.id [delete: restrict]
Ref: GIFT_COUPONS.receiver_user_id > USERS.id [delete: restrict]
Ref: GIFT_COUPON_HISTORIES.gift_coupon_id > GIFT_COUPONS.id [delete: cascade]
Ref: PROFILE_ASSETS.user_id > USERS.id [delete: cascade]
Ref: MESSAGE_REACTIONS.message_id > MESSAGES.id [delete: cascade]
Ref: MESSAGE_REACTIONS.user_id > USERS.id [delete: cascade]
